{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rollback_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rollback_id",
    "source_version",
    "target_version",
    "reason",
    "validated_target",
    "trace_id"
  ],
  "properties": {
    "rollback_id": {
      "type": "string",
      "minLength": 1
    },
    "source_version": {
      "type": "string",
      "minLength": 1
    },
    "target_version": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "validated_target": {
      "enum": [
        "validated",
        "draft"
      ],
      "type": "string"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "restored_artifacts": {
      "items": {
        "type": "string",
        "minLength": 1
      },
      "type": "array"
    }
  },
  "x-hard_rules": [
    "Rollback target must be validated or explicitly marked draft.",
    "Rollback reason must be preserved."
  ]
}
