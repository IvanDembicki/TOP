{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sensitive_import_report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "blocked",
    "findings",
    "policy_summary"
  ],
  "properties": {
    "blocked": {
      "type": "boolean"
    },
    "policy_summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "category",
          "severity",
          "action",
          "redacted_preview"
        ],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "api_key",
              "private_key",
              "pii",
              "internal_url"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "warning",
              "blocking"
            ]
          },
          "action": {
            "type": "string",
            "enum": [
              "block",
              "warn",
              "redact"
            ]
          },
          "redacted_preview": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
