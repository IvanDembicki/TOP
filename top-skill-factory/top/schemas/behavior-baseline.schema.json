{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "behavior_baseline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "baseline_id",
    "scenario_inputs",
    "expected_outputs",
    "expected_failures",
    "acceptance_assertions"
  ],
  "properties": {
    "baseline_id": {
      "type": "string",
      "minLength": 1
    },
    "scenario_inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "scenario_name",
          "input_summary"
        ],
        "properties": {
          "scenario_name": {
            "type": "string",
            "minLength": 1
          },
          "input_summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "expected_failures": {
      "items": {
        "type": "string",
        "minLength": 1
      },
      "type": "array"
    },
    "acceptance_assertions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "x-hard_rules": [
    "Behavior preservation claims require a behavior baseline.",
    "Acceptance assertions must be explicit.",
    "Baseline must be stable enough for replay or comparison."
  ]
}
