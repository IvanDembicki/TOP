{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "comparison_result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "preferred_variant",
    "reason",
    "evidence"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "draft",
        "blocked",
        "failed"
      ]
    },
    "preferred_variant": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
