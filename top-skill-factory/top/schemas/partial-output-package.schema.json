{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "partial_output_package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "delivery_type",
    "usable_artifacts",
    "known_remaining_gaps",
    "consumer_warning"
  ],
  "properties": {
    "delivery_type": {
      "type": "string",
      "const": "partial_output_package"
    },
    "usable_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "known_remaining_gaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "consumer_warning": {
      "type": "string",
      "minLength": 1
    }
  }
}
