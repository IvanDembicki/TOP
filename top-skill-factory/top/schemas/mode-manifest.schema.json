{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mode_manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "modes",
    "hard_rules"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "mode",
          "maturity",
          "input_types",
          "output_types",
          "allowed_next_modes",
          "requires_user_acceptance"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "minLength": 1
          },
          "requires_user_acceptance": {
            "type": "boolean"
          },
          "allowed_next_modes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "input_types": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "maturity": {
            "type": "string",
            "enum": [
              "stable",
              "experimental",
              "planned"
            ]
          },
          "output_types": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "hard_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stable_release_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "experimental_release_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
