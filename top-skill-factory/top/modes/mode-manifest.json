  "hard_rules": [
    "Minimal demo contract may only be used in top/examples or when demo output is explicitly requested.",
    "Mode maturity in this manifest is the source of truth for release labeling.",
    "Allowed next modes constrain declared routing, even when prompts describe broader future possibilities.",
    "Products should expose a quick startup update check based on release metadata before active work begins.",
    "The 1.0 stable workflow contract includes Create, Convert, Update, Compare, and Rollback only.",
    "Merge remains experimental and is excluded from the stable release contract.",
    "Planned modes must not be claimed stable by docs, CLI defaults, or release reports."
  ],
  "stable_release_scope": [
    "CreateNewSkillMode",
    "ConvertLegacySkillMode",
    "UpdateExistingSkillMode",
    "CompareSkillMode",
    "RollbackMode"
