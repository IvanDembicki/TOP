{
  "schema_version": "0.1",
  "skill_name": "TOP Prompt Cleaner",
  "skill_version": "1.0.0",
  "status": "stable",
  "purpose": "Convert raw prompts into cleaner structured outputs while escalating multi-step workflows.",
  "core_thesis": "A prompt is not clean until its goal, constraints, and output format are explicit and contradiction-free.",
  "root": "TOP Prompt Cleaner",
  "invariants": [
    "SensitiveDataDetector runs before any transformation.",
    "ComplexityDetector runs before any transformation.",
    "High complexity routes to escalation rather than cleaning."
  ],
  "tree": {
    "TOP Prompt Cleaner": {
      "type": "root_controller",
      "children": {
        "InputController": {
          "type": "controller",
          "prompt": "prompts/input-controller.md"
        },
        "SensitiveDataDetector": {
          "type": "validator",
          "prompt": "prompts/sensitive-data-detector.md"
        },
        "ComplexityDetector": {
          "type": "validator",
          "prompt": "prompts/complexity-detector.md"
        },
        "ModeRouter": {
          "type": "controller",
          "prompt": "prompts/mode-router.md"
        },
        "UserInteractionController": {
          "type": "controller",
          "prompt": "prompts/user-interaction-controller.md"
        },
        "ValidationController": {
          "type": "controller",
          "prompt": "prompts/validation-controller.md"
        },
        "FinalDecisionController": {
          "type": "controller",
          "prompt": "prompts/final-decision-controller.md"
        },
        "QuickCleanMode": {
          "type": "mode",
          "prompt": "modes/quick-clean.md"
        },
        "StrictMode": {
          "type": "mode",
          "prompt": "modes/strict.md"
        },
        "TargetLLMStyleMode": {
          "type": "mode",
          "prompt": "modes/target-llm-style.md"
        },
        "FactoryEscalationController": {
          "type": "controller",
          "prompt": "prompts/factory-escalation.md"
        }
      }
    }
  },
  "output_contract": {
    "required_artifacts": [
      "top/spec.json",
      "top/README.md",
      "top/artifact-manifest.json",
      "top/prompts/root.md",
      "top/prompts/mode-router.md",
      "top/prompts/input-controller.md",
      "top/prompts/user-interaction-controller.md",
      "top/prompts/validation-controller.md",
      "top/prompts/final-decision-controller.md",
      "top/modes/*",
      "top/validation/output-rules.md"
    ]
  },
  "validation_model": "llm-governed-contract-validation",
  "mode_maturity": {
    "stable": [
      "QuickCleanMode",
      "StrictMode",
      "TargetLLMStyleMode"
    ],
    "experimental": [],
    "planned": []
  }
}
