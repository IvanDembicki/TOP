{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "clarification_request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "question",
    "options"
  ],
  "properties": {
    "question": {
      "type": "string",
      "minLength": 1
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
