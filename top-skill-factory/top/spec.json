{
  "schema_version": "0.2",
  "skill_name": "TOP Skill Factory",
  "skill_version": "1.1.1",
  "status": "stable",
  "purpose": "Create, convert, update, validate, compare, debug, and document AI skills as TOP-based skill systems.",
  "core_thesis": "A skill is not a prompt. A skill is a controlled tree of responsibilities, contracts, signals, validation rules, budgets, and outputs.",
  "root": "TOP Skill Factory",
  "invariants": [
    "ModeRouter activates exactly one mode unless CompositeFlowController explicitly defines a composite flow.",
    "Leaf nodes never control flow directly. They return structured signals to their parent controller.",
    "Every forced user choice must include U = User-defined answer.",
    "User interaction is allowed only through UserInteractionController.",
    "Legacy skill is evidence, not authority.",
    "OutputAssembler cannot invent missing artifacts.",
    "If validation fails, the generated or converted skill is not ready.",
    "Core TOP invariants cannot be disabled by user override or legacy evidence.",
    "New requirements must invalidate old decisions that conflict with them.",
    "Every important decision must be traceable to inputs, constraints, explicit user decisions, or validation evidence.",
    "Blocking blind spots must be escalated or explicitly resolved before ready output.",
    "Mode handoff must use structured mode results and structured signals, not uncontrolled previous context.",
    "Required artifacts cannot be empty placeholders in a ready result.",
    "A startup update check should run before active work when release metadata and a comparison source are available."
  ],
