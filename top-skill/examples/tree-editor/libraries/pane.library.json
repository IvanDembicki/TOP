{
  "type": "PaneLibrary",
  "doc": "Canonical library namespace for editor pane nodes. Tree items attach to parent/context only and pull records, tokens, and semantic capabilities through explicit contracts.",
  "canon_status": "Canonical for top-skill 1.1.18+. No constructor data injection, no setter-style presentation propagation, and no locally implemented content selection logic.",
  "props": {
    "materializationPolicy": "source-model"
  },
  "children": [
    {
      "type": "TreeItem",
      "doc": "Library template node representing one attached item in the editor tree. It pulls its record from the owning context and owns resolved row/icon/action tokens for descendants.",
      "prompt": "prompts/pane/tree_item/TreeItem.prompt.md",
      "props": {
        "dir": "pane/tree_item",
        "contentType": "view",
        "materializationPolicy": "runtime-template"
      },
      "children": [
        {
          "type": "TreeItemRow",
          "doc": "Switchable row holder. It selects view/edit row state in the controller and exposes resolved primitive values through pull methods.",
          "prompt": "prompts/pane/tree_item/TreeItemRow.prompt.md",
          "props": {
            "contentType": "view"
          },
          "children": [
            {
              "type": "TreeItemRowViewState",
              "doc": "View-mode row state with static NodeIcon and NodeLabel children. Children pull resolved icon and label values.",
              "prompt": "prompts/pane/tree_item/TreeItemRowViewState.prompt.md",
              "props": {
                "contentType": "view"
              },
              "children": [
                {
                  "type": "NodeIcon",
                  "doc": "Static icon part. Pulls resolved icon and activation tokens; reports semantic toggle intent.",
                  "prompt": "prompts/pane/tree_item/NodeIcon.prompt.md",
                  "props": {
                    "contentType": "view"
                  }
                },
                {
                  "type": "NodeLabel",
                  "doc": "Static label part. Pulls resolved label text through controller access.",
                  "prompt": "prompts/pane/tree_item/NodeLabel.prompt.md",
                  "props": {
                    "contentType": "view"
                  }
                }
              ]
            },
            {
              "type": "TreeItemRowEditState",
              "doc": "Switchable edit-mode row holder. It selects normal/hover row state through semantic hover requests.",
              "prompt": "prompts/pane/tree_item/TreeItemRowEditState.prompt.md",
              "props": {
                "contentType": "view"
              },
              "children": [
                {
                  "type": "TreeItemRowEditStateNormalState",
                  "doc": "Normal edit row with static DragHandle, NodeIcon, and NodeLabel children. Root/non-root drag affordance is a resolved token, not conditional child creation.",
                  "prompt": "prompts/pane/tree_item/TreeItemRowEditStateNormalState.prompt.md",
                  "props": {
                    "contentType": "view"
                  },
                  "children": [
                    {
                      "type": "DragHandle",
                      "doc": "Static drag affordance part. Pulls resolved drag token.",
                      "prompt": "prompts/pane/tree_item/DragHandle.prompt.md",
                      "props": {
                        "contentType": "view"
                      }
                    },
                    {
                      "type": "NodeIcon",
                      "doc": "Static icon part. Pulls resolved icon and activation tokens; reports semantic toggle intent.",
                      "prompt": "prompts/pane/tree_item/NodeIcon.prompt.md",
                      "props": {
                        "contentType": "view"
                      }
                    },
                    {
                      "type": "NodeLabel",
                      "doc": "Static label part. Pulls resolved label text through controller access.",
                      "prompt": "prompts/pane/tree_item/NodeLabel.prompt.md",
                      "props": {
                        "contentType": "view"
                      }
                    }
                  ]
                },
                {
                  "type": "TreeItemRowEditStateHoverState",
                  "doc": "Hover edit row with static DragHandle, NodeIcon, NodeLabel, AddBtn, and DeleteBtn children. Availability is represented by resolved tokens.",
                  "prompt": "prompts/pane/tree_item/TreeItemRowEditStateHoverState.prompt.md",
                  "props": {
                    "contentType": "view"
                  },
                  "children": [
                    {
                      "type": "DragHandle",
                      "doc": "Static drag affordance part. Pulls resolved drag token.",
                      "prompt": "prompts/pane/tree_item/DragHandle.prompt.md",
                      "props": {
                        "contentType": "view"
                      }
                    },
                    {
                      "type": "NodeIcon",
                      "doc": "Static icon part. Pulls resolved icon and activation tokens; reports semantic toggle intent.",
                      "prompt": "prompts/pane/tree_item/NodeIcon.prompt.md",
                      "props": {
                        "contentType": "view"
                      }
                    },
                    {
                      "type": "NodeLabel",
                      "doc": "Static label part. Pulls resolved label text through controller access.",
                      "prompt": "prompts/pane/tree_item/NodeLabel.prompt.md",
                      "props": {
                        "contentType": "view"
                      }
                    },
                    {
                      "type": "AddBtn",
                      "doc": "Static add action part. Reports semantic add intent.",
                      "prompt": "prompts/pane/tree_item/AddBtn.prompt.md",
                      "props": {
                        "contentType": "view"
                      }
                    },
                    {
                      "type": "DeleteBtn",
                      "doc": "Static delete action part. Pulls resolved availability token and reports semantic delete intent.",
                      "prompt": "prompts/pane/tree_item/DeleteBtn.prompt.md",
                      "props": {
                        "contentType": "view"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "ExpandCollapseHolder",
          "doc": "Switchable state holder owning expanded/collapsed state. Active state is represented by explicit child state identity.",
          "prompt": "prompts/pane/tree_item/ExpandCollapseHolder.prompt.md",
          "props": {
            "contentType": "view"
          },
          "children": [
            {
              "type": "ExpandedState",
              "doc": "Expanded state node. Owns ChildrenList branch lifecycle and exposes its opaque handle through direct parent pull.",
              "prompt": "prompts/pane/tree_item/ExpandedState.prompt.md",
              "children": [
                {
                  "type": "ChildrenList",
                  "doc": "Data/presentation boundary for child TreeItem instances. It pulls child records from the owning TreeItem and attaches each TreeItem to context only.",
                  "prompt": "prompts/pane/tree_item/ChildrenList.prompt.md",
                  "props": {
                    "contentType": "view"
                  },
                  "children": [
                    {
                      "type": "lib:pane.TreeItem",
                      "doc": "Runtime child item attached to ChildrenList context. The record is pulled through the parent contract.",
                      "props": {
                        "materializationPolicy": "runtime-library-reference"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "CollapsedState",
              "doc": "Collapsed state node. It has no content and no children; its activation represents the collapsed branch.",
              "prompt": "prompts/pane/tree_item/CollapsedState.prompt.md"
            }
          ]
        }
      ]
    }
  ]
}
