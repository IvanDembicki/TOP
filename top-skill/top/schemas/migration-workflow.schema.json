{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://top.local/schemas/migration-workflow.schema.json",
  "title": "TOP Migration Workflow",
  "type": "object",
  "required": [
    "schemaVersion",
    "migrationId",
    "requestedScope",
    "selectedScope",
    "branchId",
    "currentPhase",
    "phases",
    "validationGates"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "migrationId": {
      "type": "string",
      "minLength": 1
    },
    "projectPath": {
      "type": "string"
    },
    "requestedScope": {
      "type": [
        "string",
        "null"
      ]
    },
    "selectedScope": {
      "type": "string",
      "minLength": 1
    },
    "branchId": {
      "type": "string",
      "minLength": 1
    },
    "currentPhase": {
      "type": "string",
      "minLength": 1
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/phase"
      }
    },
    "validationGates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "executionEvidence": {
      "$ref": "https://top.local/schemas/fragments/execution-evidence.schema.json"
    },
    "handoffRules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/handoff"
      }
    },
    "decisionTrace": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "separationOfPowers": {
      "$ref": "#/$defs/separationOfPowers"
    },
    "deliveryCertification": {
      "$ref": "#/$defs/deliveryCertification"
    }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "required": [
        "id",
        "agent",
        "status",
        "next"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "pending",
            "active",
            "blocked",
            "done",
            "skipped"
          ]
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "gates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockingReason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "gate": {
      "type": "object",
      "required": [
        "id",
        "status",
        "condition"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "status": {
          "enum": [
            "pending",
            "pass",
            "fail",
            "not_verified",
            "not_applicable"
          ]
        },
        "condition": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "handoff": {
      "type": "object",
      "required": [
        "from",
        "to",
        "condition"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": [
        "decisionId",
        "status",
        "reason",
        "evidence"
      ],
      "properties": {
        "decisionId": {
          "type": "string"
        },
        "status": {
          "enum": [
            "active",
            "invalidated",
            "superseded"
          ]
        },
        "reason": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supersededBy": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "separationOfPowers": {
      "type": "object",
      "required": [
        "executivePassId",
        "judicialPassId",
        "reportingPassId",
        "selfCertificationAllowed"
      ],
      "properties": {
        "executivePassId": {
          "type": "string",
          "minLength": 1
        },
        "judicialPassId": {
          "type": "string",
          "minLength": 1
        },
        "reportingPassId": {
          "type": "string",
          "minLength": 1
        },
        "selfCertificationAllowed": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "deliveryCertification": {
      "type": "object",
      "required": [
        "status",
        "executionEvidence",
        "judicialPassId",
        "judicialHandoffRef",
        "validationReportRef",
        "selfCertificationAllowed",
        "requiredHardChecks",
        "noRequiredGateFailedOrNotVerified"
      ],
      "properties": {
        "status": {
          "enum": [
            "not-started",
            "in-progress",
            "blocked",
            "partial",
            "not-verified",
            "not-certified",
            "complete"
          ]
        },
        "executionEvidence": {
          "$ref": "https://top.local/schemas/fragments/execution-evidence.schema.json"
        },
        "judicialPassId": {
          "type": "string",
          "minLength": 1
        },
        "judicialHandoffRef": {
          "type": "string",
          "minLength": 1
        },
        "validationReportRef": {
          "type": "string",
          "minLength": 1
        },
        "finalAuditReportRef": {
          "type": "string"
        },
        "certifiedByPassId": {
          "type": "string"
        },
        "selfCertificationAllowed": {
          "const": false
        },
        "requiredHardChecks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hardCheck"
          }
        },
        "noRequiredGateFailedOrNotVerified": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "complete"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "executionEvidence": {
                "properties": {
                  "executionIsolationLevel": {
                    "const": "runner-enforced"
                  },
                  "verificationEvidenceLevel": {
                    "const": "hard-check-verified"
                  }
                }
              },
              "noRequiredGateFailedOrNotVerified": {
                "const": true
              }
            },
            "required": [
              "judicialHandoffRef",
              "finalAuditReportRef",
              "certifiedByPassId",
              "noRequiredGateFailedOrNotVerified"
            ]
          }
        }
      ],
      "additionalProperties": false
    },
    "hardCheck": {
      "type": "object",
      "required": [
        "id",
        "description",
        "requiredForComplete",
        "status",
        "command",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "requiredForComplete": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "pass",
            "fail",
            "not_verified",
            "not_applicable"
          ]
        },
        "command": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
